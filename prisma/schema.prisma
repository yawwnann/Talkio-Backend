// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  THERAPIST
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  recoveryPin     String?
  role            Role             @default(PARENT)
  name            String?
  isBlocked       Boolean          @default(false)
  blockedReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  children        Child[]
  therapySessions TherapySession[] @relation("TherapistSessions")
  educationContents EducationContent[]
  progressNotes   ProgressNote[]
  therapistReviews Review[]         @relation("TherapistReviews")
  parentReviews    Review[]         @relation("ParentReviews")
  notifications    Notification[]

  @@map("users")
}

model Child {
  id              String            @id @default(uuid())
  parentId        String
  parent          User              @relation(fields: [parentId], references: [id])
  name            String
  dateOfBirth     DateTime
  gender          Gender
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  diagnoses       Diagnosis[]
  therapySessions TherapySession[]
  gameLogs        GameLog[]
  progressUploads ProgressUpload[]
  progressNotes   ProgressNote[]
  articulationSessions ArticulationSession[]

  @@map("children")
}

model Diagnosis {
  id             String         @id @default(uuid())
  childId        String
  child          Child          @relation(fields: [childId], references: [id])
  answers        Json           // Jawaban pertanyaan
  ageInMonths    Int            // Usia anak dalam bulan saat diagnosis
  ageCategory    String         // Kategori usia (Infant, Toddler, Preschool)
  riskLevel      RiskLevel
  confidence     Float          @default(0.95) // Confidence score (0-1)
  score          Int            // Skor dalam persen (0-100)
  derivedFacts   Json           // Fakta yang diturunkan dari forward chaining
  triggeredRules Json           // Rules yang dipicu
  findings       Json          // Temuan per kategori
  recommendations Json        // Array rekomendasi
  summary        String?       // Ringkasan text
  symptom        String?       @db.Text // Backward compatibility
  createdAt      DateTime       @default(now())


  @@map("diagnoses")
}

model TherapySession {
  id            String        @id @default(uuid())
  childId       String
  child         Child         @relation(fields: [childId], references: [id])
  therapistId   String?
  therapist     User?         @relation("TherapistSessions", fields: [therapistId], references: [id])
  schedule      DateTime
  paymentStatus PaymentStatus @default(PENDING)
  therapyType   String
  isActive      Boolean       @default(false)
  sessionStatus String        @default("SCHEDULED")
  transactionId String?
  paymentUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("therapy_sessions")
}

model GameLog {
  id        String   @id @default(uuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id])
  gameScore Int
  duration  Int      // in seconds
  gameType  String
  playedAt  DateTime @default(now())

  @@map("game_logs")
}

model ArticulationSession {
  id           String   @id @default(uuid())
  childId      String
  child        Child    @relation(fields: [childId], references: [id])

  // Latihan info
  targetWord   String   // "RUSUK", "RUMAH", dst
  targetSound  String   // "R", "S", "L", "N"
  roundNumber  Int      @default(1)

  // Parent scoring (manual)
  parentRating Boolean?  // null = belum dinilai, true = 👍 benar, false = 👎 belum
  parentNotes String?   // Catatan orang tua

  // Audio recording
  audioUrl     String?  // URL file audio di VPS

  // Session info
  sessionScore Int      @default(0)
  playedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  // ============ THERAPIST REVIEW FIELDS ============
  therapistId        String?   // ID terapis yang mereview
  therapistRating    String?   // "OKE" = baik, "BELUM_OK" = perlu latihan lagi
  therapistScore     Int?      // Skor 0-100 dari terapis
  therapistNotes     String?   @db.Text // Catatan/feedback dari terapis
  suggestedWords     String?   // JSON array: ["RAJA", "ROTI", "RUSA"]
  reviewedAt         DateTime? // Waktu review
  // =================================================

  @@index([childId, targetSound])
  @@index([childId, createdAt])
  @@map("articulation_sessions")
}

model ProgressUpload {
  id                  String   @id @default(uuid())
  childId             String
  child               Child    @relation(fields: [childId], references: [id])
  fileUrl             String
  cloudinaryPublicId  String?
  parentNotes         String?
  therapistEvaluation String?
  fileType            String?  @default("image")
  duration            Int?
  createdAt           DateTime @default(now())

  @@map("progress_uploads")
}

model ProgressNote {
  id          String   @id @default(uuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id])
  therapistId String
  therapist   User     @relation(fields: [therapistId], references: [id])
  title       String
  content     String   @db.Text
  status      String   @default("DRAFT")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("progress_notes")
}



model EducationContent {
  id          String   @id @default(uuid())
  title       String
  description String?  // Deskripsi singkat konten
  content     String   // Text untuk article, URL untuk video
  type        String   // 'ARTICLE' atau 'VIDEO'
  thumbnail   String?  // URL thumbnail untuk video
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  isActive    Boolean  @default(true)
  order       Int      @default(0) // Urutan tampilan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("education_contents")
}

model Asset {
  id          String   @id @default(uuid())
  kode        String   @unique   // Kode unik aset, misal AST-001
  nama        String             // Nama barang/aset
  kategori    String?            // Kategori aset
  jumlah      Int      @default(0)
  satuan      String?            // Pcs, Unit, Set, dll
  keterangan  String?
  kondisi     String   @default("BAIK") // BAIK, RUSAK, TIDAK_ADA
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assets")
}

model Review {
  id              String   @id @default(uuid())
  therapistId     String
  therapist       User     @relation("TherapistReviews", fields: [therapistId], references: [id], onDelete: Cascade)
  parentId        String
  parent          User     @relation("ParentReviews", fields: [parentId], references: [id], onDelete: Cascade)
  rating          Int      @default(5)
  developmentTime String
  comment         String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  childId   String?  // For PROGRESS_UPLOAD notifications - links to the child
  createdAt DateTime @default(now())

  @@map("notifications")
}
