# TiDB MySQL Connection
# Format: mysql://user:password@host:port/database
# 
# Untuk TiDB Cloud:
# DATABASE_URL=mysql://[USER]:[PASSWORD]@[HOST].aws.tidbcloud.com:4000/[DATABASE]
#
# Untuk Local MySQL:
# DATABASE_URL=mysql://root:password@localhost:3306/speech_delay_db

DATABASE_URL=mysql://root@localhost:4000/speech_delay_db

# JWT Secret - GANTI DENGAN SECRET YANG AMAN
JWT_SECRET="your-super-secret-key-change-this"

# Server Configuration
PORT=3000
NODE_ENV=development

# Midtrans Payment Gateway
# Dapatkan dari: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION=false

# ML Python Microservice (Opsional)
# URL ke service Python untuk prediksi ML
ML_SERVICE_URL=http://localhost:5000
ML_API_TIMEOUT=10000
ML_MODEL_VERSION=v1.0.0

# Frontend URL (untuk payment callback)
FRONTEND_URL=http://localhost:3000

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=progress_uploads
